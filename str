import java.util.HashSet;
import java.util.Set;

class str {
    public int lengthOfLongestSubstring(String s) {
       
        if (s == null || s.isEmpty()) {
            return 0;
        }

        
        Set<Character> charactersInWindow = new HashSet<>();
        
        int maxLength = 0;
        int windowStart = 0;

        for (int windowEnd = 0; windowEnd < s.length(); windowEnd++) {
            char currentLetter = s.charAt(windowEnd);

            
            
            while (charactersInWindow.contains(currentLetter)) {
                char letterAtStart = s.charAt(windowStart);
                charactersInWindow.remove(letterAtStart);
                windowStart++;
            }

           
            charactersInWindow.add(currentLetter);

            
            int currentWindowSize = windowEnd - windowStart + 1;
            maxLength = Math.max(maxLength, currentWindowSize);
        }

        return maxLength;
    }
}
