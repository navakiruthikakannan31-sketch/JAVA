class prefix {
    public String longestCommonPrefix(String[] strs) {
        // Base case: If the array is null or empty, there's no prefix
        if (strs == null || strs.length == 0) {
            return "";
        }

        // Start by assuming the entire first word is the common prefix
        String prefix = strs[0];

        // Compare the prefix with every other string in the array
        for (int i = 1; i < strs.length; i++) {
            // While the current string does NOT start with our prefix
            while (strs[i].indexOf(prefix) != 0) {
                // Shorten the prefix by one character from the end
                prefix = prefix.substring(0, prefix.length() - 1);

                // If the prefix becomes empty, there is no common prefix at all
                if (prefix.isEmpty()) {
                    return "";
                }
            }
        }

        return prefix;
    }
}
